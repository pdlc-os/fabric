FROM fabric-base:latest

# Install Amp CLI via npm. fabric-base provides node, npm, python3, git, tmux,
# and fabrictool — no additional system packages are needed.
RUN npm install -g @sourcegraph/amp@latest \
    && amp --version

USER fabric
WORKDIR /workspace
