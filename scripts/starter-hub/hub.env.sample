# Fabric Hub Environment Configuration
# Copy this file to .scratch/hub-<name>.env (e.g., hub-demo.env) and fill in
# your values. The deploy script (gce-start-hub.sh --full) uploads it to the
# instance. The file name must match your HUB_NAME (default: "demo").

# === Required ===
FABRIC_HUB_STORAGE_BUCKET=your-gcs-bucket-name
SESSION_SECRET=<generate-with: openssl rand -base64 32>

# === Hub & Registry ===
# Public URL of the Hub (critical for OAuth redirects)
FABRIC_SERVER_BASE_URL=https://your-hub-domain.example.com
FABRIC_IMAGE_REGISTRY=your-registry.example.com/your-project/your-repo

# (Optional) Fallback for client/agent communication if different from BASE_URL
# FABRIC_HUB_ENDPOINT=https://your-hub-domain.example.com

# === OAuth — Web Clients ===
# See docs: https://fabric-ai.dev/hub-admin/auth/
FABRIC_SERVER_OAUTH_WEB_GOOGLE_CLIENTID=your-google-web-client-id.apps.googleusercontent.com
FABRIC_SERVER_OAUTH_WEB_GOOGLE_CLIENTSECRET=your-google-web-client-secret
FABRIC_SERVER_OAUTH_WEB_GITHUB_CLIENTID=your-github-web-client-id
FABRIC_SERVER_OAUTH_WEB_GITHUB_CLIENTSECRET=your-github-web-client-secret

# === OAuth — CLI Clients ===
FABRIC_SERVER_OAUTH_CLI_GOOGLE_CLIENTID=your-google-cli-client-id.apps.googleusercontent.com
FABRIC_SERVER_OAUTH_CLI_GOOGLE_CLIENTSECRET=your-google-cli-client-secret
FABRIC_SERVER_OAUTH_CLI_GITHUB_CLIENTID=your-github-cli-client-id
FABRIC_SERVER_OAUTH_CLI_GITHUB_CLIENTSECRET=your-github-cli-client-secret

# === Domain Authorization (optional) ===
# Comma-separated list of allowed email domains. Empty = allow all.
# FABRIC_SERVER_AUTH_AUTHORIZEDDOMAINS=example.com,mycompany.org

# === Admin Emails (optional) ===
# Comma-separated list of email addresses to auto-promote to admin role on login.
# FABRIC_SERVER_HUB_ADMINEMAILS=admin@example.com,ops@mycompany.org

# === Telemetry (OTEL) ===
# Hub-side telemetry configuration. Loaded by the systemd unit via EnvironmentFile.
# GCP-native mode uses Cloud Trace, Cloud Monitoring, and Cloud Logging SDKs
# directly — no OTLP endpoint is needed. Auth uses ADC or an explicit SA key.
FABRIC_CLOUD_LOGGING=true
FABRIC_GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
FABRIC_TELEMETRY_CLOUD_PROVIDER=gcp
FABRIC_OTEL_LOG_ENABLED=true

# === Maintenance / Self-Update ===
# Path to the fabric source checkout used by rebuild-server and rebuild-web.
# Append @branch to pin to a specific git branch (e.g., feature-branch).
# Without @branch, rebuilds stay on whatever branch is currently checked out.
# FABRIC_MAINTENANCE_REPO_PATH=/home/fabric/fabric@main
#
# Or set the branch separately (overrides the @branch in REPO_PATH):
# FABRIC_MAINTENANCE_REPO_BRANCH=main

# === Optional ===
# FABRIC_LOG_LEVEL=debug
