const base = import.meta.env.BASE_URL;
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Fabric — Multi-Agent Orchestration for Deep Agents</title>
  <meta name="description" content="Run multiple AI agents in parallel, each in its own container with isolated workspaces. Orchestrate Claude Code, Gemini CLI, Codex, and more." />
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

  <!-- Fonts for both landing page and integrated slideshow -->
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Outfit:wght@400;500;600;700;800&display=swap" />

  <style>
    /* ========================================================================
       Landing Page Base Styles
       ======================================================================== */
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --bg-primary: #0a0a0f;
      --bg-secondary: #12121a;
      --bg-card: #1a1a25;
      --border-subtle: #2a2a3a;
      --text-primary: #e8e8ed;
      --text-secondary: #9a9ab0;
      --text-muted: #6a6a80;
      --accent-green: #4ade80;
      --accent-green-dim: #22633e;
      --accent-emerald: #34d399;
      --gradient-start: #4ade80;
      --gradient-end: #06b6d4;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg-primary);
      color: var(--text-primary);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    /* Hero */
    .hero {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 6rem 2rem 5rem;
      text-align: center;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 800px;
      height: 600px;
      background: radial-gradient(ellipse, rgba(74, 222, 128, 0.06) 0%, transparent 70%);
      pointer-events: none;
    }

    .hero-graphic {
      max-width: 680px;
      width: 100%;
      margin-bottom: 2rem;
      filter: drop-shadow(0 0 60px rgba(74, 222, 128, 0.12));
    }

    .hero-tagline {
      font-size: 1.1rem;
      color: var(--text-muted);
      font-style: italic;
      margin-bottom: 1.5rem;
      letter-spacing: 0.02em;
    }

    .hero-subtitle {
      font-size: 1.35rem;
      color: var(--text-secondary);
      max-width: 720px;
      line-height: 1.7;
      margin-bottom: 2.5rem;
      font-weight: 300;
    }

    .hero-buttons {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.8rem 1.8rem;
      border-radius: 8px;
      font-size: 0.95rem;
      font-weight: 500;
      text-decoration: none;
      transition: all 0.2s ease;
      cursor: pointer;
      border: none;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
      color: #0a0a0f;
    }

    .btn-primary:hover {
      filter: brightness(1.1);
      transform: translateY(-1px);
      box-shadow: 0 4px 20px rgba(74, 222, 128, 0.3);
    }

    .btn-secondary {
      background: transparent;
      color: var(--text-primary);
      border: 1px solid var(--border-subtle);
    }

    .btn-secondary:hover {
      border-color: var(--accent-green);
      color: var(--accent-green);
      transform: translateY(-1px);
    }

    .btn svg { width: 18px; height: 18px; }

    /* Section layout */
    .landing-section {
      padding: 5rem 2rem;
    }

    .section-inner {
      max-width: 1100px;
      margin: 0 auto;
    }

    .section-title {
      font-size: 2rem;
      font-weight: 600;
      text-align: center;
      margin-bottom: 1rem;
      background: linear-gradient(135deg, var(--text-primary), var(--text-secondary));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .section-subtitle {
      text-align: center;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 auto 3rem;
      font-weight: 300;
    }

    /* Feature grid */
    .features {
      background: var(--bg-primary);
    }

    .feature-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem;
    }

    .feature-card {
      background: var(--bg-card);
      border: 1px solid var(--border-subtle);
      border-radius: 12px;
      padding: 1.8rem;
      transition: border-color 0.2s ease, transform 0.2s ease;
    }

    .feature-card:hover {
      border-color: var(--accent-green-dim);
      transform: translateY(-2px);
    }

    .feature-icon {
      margin-bottom: 0.8rem;
      display: block;
      width: 36px;
      height: 36px;
      color: var(--accent-green);
    }

    .feature-card h3 {
      font-size: 1.05rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
    }

    .feature-card p {
      font-size: 0.9rem;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    .feature-card ul {
      list-style: none;
      padding: 0;
      margin: 0.5rem 0 0;
    }

    .feature-card ul li {
      font-size: 0.85rem;
      color: var(--text-secondary);
      line-height: 1.6;
      padding-left: 1.1rem;
      position: relative;
      margin-bottom: 0.3rem;
    }

    .feature-card ul li::before {
      content: '\203A';
      position: absolute;
      left: 0;
      color: var(--accent-green);
      font-weight: 600;
    }

    /* Video section */
    .video-section {
      background: var(--bg-secondary);
      border-top: 1px solid var(--border-subtle);
      border-bottom: 1px solid var(--border-subtle);
    }

    .video-container {
      position: relative;
      width: 100%;
      max-width: 900px;
      margin: 0 auto;
      padding-top: 56.25%;
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid var(--border-subtle);
      box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
    }

    .video-container iframe {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border: none;
    }

    /* How it works */
    .how-it-works {
      background: var(--bg-primary);
    }

    .steps {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 2rem;
      max-width: 900px;
      margin: 0 auto;
    }

    .step { text-align: center; }

    .step-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: var(--accent-green-dim);
      color: var(--accent-green);
      font-weight: 600;
      font-size: 1rem;
      margin-bottom: 1rem;
    }

    .step h3 { font-size: 1rem; margin-bottom: 0.4rem; color: var(--text-primary); }
    .step p { font-size: 0.85rem; color: var(--text-secondary); }

    .step code {
      display: block;
      margin-top: 0.5rem;
      font-size: 0.8rem;
      color: var(--accent-emerald);
      background: var(--bg-card);
      padding: 0.4rem 0.8rem;
      border-radius: 6px;
      font-family: 'SF Mono', 'Fira Code', monospace;
    }

    /* CTA */
    .cta {
      background: var(--bg-primary);
      text-align: center;
      padding: 5rem 2rem;
    }

    .cta .section-title { margin-bottom: 1.5rem; }

    .cta-links {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* Footer */
    .landing-footer {
      padding: 2rem;
      text-align: center;
      color: var(--text-muted);
      font-size: 0.8rem;
      border-top: 1px solid var(--border-subtle);
    }

    .landing-footer a { color: var(--text-secondary); text-decoration: none; }
    .landing-footer a:hover { color: var(--accent-green); }

    /* Deep dive link */
    .deep-dive-link {
      text-align: center;
      margin-top: 1.5rem;
      font-size: 0.9rem;
    }

    .deep-dive-link a {
      color: var(--text-secondary);
      text-decoration: none;
      transition: color 0.2s;
    }

    .deep-dive-link a:hover {
      color: var(--accent-green);
    }

    /* Responsive */
    @media (max-width: 640px) {
      .hero { padding: 3rem 1.5rem 2rem; }
      .hero-subtitle { font-size: 1.1rem; }
      .section-title { font-size: 1.5rem; }
      .feature-grid { grid-template-columns: 1fr; }
    }

    /* ========================================================================
       Integrated Slideshow (scoped under .fabric-deck)
       ======================================================================== */
    .fabric-deck {
      --fabric-bg: #0f172a;
      --fabric-bg-subtle: #1e293b;
      --fabric-surface: #1e293b;
      --fabric-surface-raised: #334155;
      --fabric-border: #334155;
      --fabric-border-hover: #475569;
      --fabric-primary: #60a5fa;
      --fabric-primary-hover: #93c5fd;
      --fabric-primary-active: #3b82f6;
      --fabric-primary-muted: rgba(96, 165, 250, 0.15);
      --fabric-success: #22c55e;
      --fabric-warning: #f59e0b;
      --fabric-danger: #ef4444;
      --fabric-info: #60a5fa;
      --fabric-text: #f1f5f9;
      --fabric-text-secondary: #cbd5e1;
      --fabric-text-muted: #94a3b8;
      --fabric-text-disabled: #64748b;
      --font-sans: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
      --font-header: 'Outfit', var(--font-sans);
      --font-mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, monospace;
      --fabric-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.3), 0 2px 4px -2px rgb(0 0 0 / 0.3);
      --fabric-shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.4), 0 4px 6px -4px rgb(0 0 0 / 0.4);
      --fabric-radius-sm: 0.25rem;
      --fabric-radius: 0.5rem;
      --fabric-radius-lg: 0.75rem;
      --fabric-radius-xl: 1rem;
      --transition-fast: 150ms ease;
      --transition-normal: 300ms cubic-bezier(0.4, 0, 0.2, 1);
      --transition-slow: 500ms cubic-bezier(0.4, 0, 0.2, 1);

      position: relative;
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      aspect-ratio: 16 / 9;
      background-color: var(--fabric-bg);
      border: 1px solid var(--fabric-border);
      border-radius: var(--fabric-radius-xl);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      font-family: var(--font-sans);
      color: var(--fabric-text);
      -webkit-font-smoothing: antialiased;
    }

    /* Background glows inside the deck */
    .fabric-deck .bg-glows {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      overflow: hidden;
      z-index: 1;
      pointer-events: none;
    }

    .fabric-deck .bg-glow-1 {
      position: absolute;
      top: -10%; right: -10%;
      width: 50%; height: 50%;
      background: radial-gradient(circle, rgba(96, 165, 250, 0.08) 0%, transparent 70%);
      filter: blur(80px);
    }

    .fabric-deck .bg-glow-2 {
      position: absolute;
      bottom: -10%; left: -10%;
      width: 60%; height: 60%;
      background: radial-gradient(circle, rgba(99, 102, 241, 0.06) 0%, transparent 70%);
      filter: blur(100px);
    }

    /* Deck header */
    .fabric-deck .presentation-header {
      height: 42px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 1.5rem;
      border-bottom: 1px solid var(--fabric-border);
      background-color: rgba(15, 23, 42, 0.8);
      backdrop-filter: blur(12px);
      z-index: 10;
      flex-shrink: 0;
    }

    .fabric-deck .logo-container {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .fabric-deck .logo-text {
      font-family: var(--font-header);
      font-weight: 800;
      font-size: 1.2rem;
      letter-spacing: -0.025em;
      color: var(--fabric-text);
    }

    .fabric-deck .logo-text span { color: var(--fabric-primary); }

    .fabric-deck .deck-title {
      font-family: var(--font-header);
      font-weight: 500;
      font-size: 0.75rem;
      color: var(--fabric-text-muted);
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    /* Slides wrapper */
    .fabric-deck .slides-wrapper {
      flex: 1;
      position: relative;
      width: 100%;
      min-height: 0;
      z-index: 2;
    }

    .fabric-deck .slide {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      display: grid;
      grid-template-columns: 45% 55%;
      padding: 0.75rem 1.5rem;
      gap: 1.5rem;
      opacity: 0;
      pointer-events: none;
      transform: translateX(60px);
      transition: opacity var(--transition-slow), transform var(--transition-slow);
      z-index: 5;
    }

    .fabric-deck .slide.active {
      opacity: 1;
      pointer-events: auto;
      transform: translateX(0);
      z-index: 6;
    }

    .fabric-deck .slide.previous {
      opacity: 0;
      pointer-events: none;
      transform: translateX(-60px);
    }

    .fabric-deck .slide.slide-full {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
    }

    /* Slide content */
    .fabric-deck .slide-content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      height: 100%;
      overflow-y: auto;
    }

    .fabric-deck .slide-title {
      font-family: var(--font-header);
      font-size: 1.6rem;
      font-weight: 700;
      line-height: 1.15;
      color: var(--fabric-text);
      margin-bottom: 0.5rem;
      letter-spacing: -0.02em;
    }

    .fabric-deck .slide-desc {
      font-size: 0.85rem;
      color: var(--fabric-text-secondary);
      line-height: 1.5;
      margin-bottom: 0.75rem;
    }

    .fabric-deck .slide-bullets {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .fabric-deck .slide-bullets li {
      position: relative;
      padding-left: 1.5rem;
      font-size: 0.82rem;
      color: var(--fabric-text-secondary);
      line-height: 1.5;
    }

    .fabric-deck .slide-bullets li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0.4rem;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background-color: var(--fabric-primary);
      box-shadow: 0 0 4px var(--fabric-primary);
    }

    .fabric-deck .slide-bullets li strong {
      color: var(--fabric-text);
      font-weight: 600;
    }

    .fabric-deck .slide-bullets li ul {
      list-style: none;
      padding: 0.25rem 0 0 0;
    }

    .fabric-deck .slide-bullets li ul li {
      padding-left: 0;
      font-size: 0.78rem;
    }

    .fabric-deck .slide-bullets li ul li::before {
      display: none;
    }

    /* Slide visual (right panel) */
    .fabric-deck .slide-visual {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100%;
    }

    .fabric-deck .visual-panel {
      width: 100%;
      height: 90%;
      background: rgba(30, 41, 59, 0.4);
      border: 1px solid var(--fabric-border);
      border-radius: var(--fabric-radius-xl);
      backdrop-filter: blur(12px);
      padding: 1rem;
      box-shadow: var(--fabric-shadow-lg);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .fabric-deck .panel-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.75rem;
      border-bottom: 1px solid rgba(51, 65, 85, 0.5);
      padding-bottom: 0.5rem;
    }

    .fabric-deck .panel-title {
      font-family: var(--font-header);
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--fabric-text-secondary);
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    .fabric-deck .panel-title svg {
      width: 14px; height: 14px;
      color: var(--fabric-primary);
    }

    .fabric-deck .panel-controls {
      display: flex;
      gap: 0.35rem;
    }

    .fabric-deck .window-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background-color: #334155;
    }

    .fabric-deck .window-dot.red { background-color: var(--fabric-danger); opacity: 0.7; }
    .fabric-deck .window-dot.yellow { background-color: var(--fabric-warning); opacity: 0.7; }
    .fabric-deck .window-dot.green { background-color: var(--fabric-success); opacity: 0.7; }

    /* Footer nav */
    .fabric-deck .presentation-footer {
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 1.5rem;
      border-top: 1px solid var(--fabric-border);
      background-color: rgba(15, 23, 42, 0.9);
      backdrop-filter: blur(12px);
      z-index: 10;
      flex-shrink: 0;
    }

    .fabric-deck .footer-instructions {
      font-size: 0.65rem;
      color: var(--fabric-text-muted);
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .fabric-deck .key-badge {
      background-color: var(--fabric-surface);
      border: 1px solid var(--fabric-border);
      padding: 0.1rem 0.3rem;
      border-radius: var(--fabric-radius-sm);
      font-family: var(--font-mono);
      font-size: 0.6rem;
      color: var(--fabric-text-secondary);
    }

    .fabric-deck .footer-nav {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .fabric-deck .progress-dots {
      display: flex;
      gap: 0.35rem;
    }

    .fabric-deck .progress-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background-color: var(--fabric-border);
      cursor: pointer;
      transition: background-color var(--transition-fast), transform var(--transition-fast);
    }

    .fabric-deck .progress-dot.active {
      background-color: var(--fabric-primary);
      transform: scale(1.3);
      box-shadow: 0 0 6px var(--fabric-primary);
    }

    .fabric-deck .nav-buttons {
      display: flex;
      gap: 0.35rem;
    }

    .fabric-deck .nav-btn {
      background: var(--fabric-surface);
      border: 1px solid var(--fabric-border);
      color: var(--fabric-text);
      padding: 0.3rem;
      border-radius: var(--fabric-radius);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all var(--transition-fast);
    }

    .fabric-deck .nav-btn:hover:not(:disabled) {
      border-color: var(--fabric-primary);
      color: var(--fabric-primary);
      background: var(--fabric-primary-muted);
    }

    .fabric-deck .nav-btn:disabled { opacity: 0.3; cursor: not-allowed; }
    .fabric-deck .nav-btn svg { width: 14px; height: 14px; }

    /* Progress bar */
    .fabric-deck .bottom-progress-bar {
      position: absolute;
      bottom: 0; left: 0;
      height: 2px;
      background-color: var(--fabric-primary);
      width: 0%;
      transition: width var(--transition-normal);
      z-index: 100;
      box-shadow: 0 0 6px var(--fabric-primary);
    }

    /* Agenda slide (slide 0) */
    .fabric-deck .agenda-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 0.75rem;
      width: 95%;
      max-width: 1000px;
      margin: 0 auto;
    }

    .fabric-deck .agenda-card {
      background: rgba(30, 41, 59, 0.25);
      border: 1px solid var(--fabric-border);
      border-radius: var(--fabric-radius-lg);
      padding: 1.25rem 0.75rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      transition: transform var(--transition-normal), border-color var(--transition-normal), box-shadow var(--transition-normal), background var(--transition-normal);
      text-align: center;
      cursor: pointer;
    }

    .fabric-deck .agenda-card .agenda-num {
      font-family: var(--font-header);
      font-size: 2rem;
      font-weight: 800;
      line-height: 1;
      transition: transform var(--transition-normal);
    }

    .fabric-deck .agenda-card .agenda-title {
      font-family: var(--font-header);
      font-size: 1rem;
      font-weight: 700;
      margin: 0;
      color: var(--fabric-text);
    }

    .fabric-deck .agenda-card .agenda-subtitle {
      font-size: 0.7rem;
      color: var(--fabric-text-muted);
      margin: 0;
    }

    .fabric-deck .agenda-card:nth-child(1) { border-color: rgba(245, 158, 11, 0.25); }
    .fabric-deck .agenda-card:nth-child(1) .agenda-num { color: #f59e0b; }
    .fabric-deck .agenda-card:nth-child(1):hover { border-color: #f59e0b; box-shadow: 0 4px 16px rgba(245, 158, 11, 0.2); }

    .fabric-deck .agenda-card:nth-child(2) { border-color: rgba(168, 85, 247, 0.25); }
    .fabric-deck .agenda-card:nth-child(2) .agenda-num { color: #a855f7; }
    .fabric-deck .agenda-card:nth-child(2):hover { border-color: #a855f7; box-shadow: 0 4px 16px rgba(168, 85, 247, 0.2); }

    .fabric-deck .agenda-card:nth-child(3) { border-color: rgba(59, 130, 246, 0.25); }
    .fabric-deck .agenda-card:nth-child(3) .agenda-num { color: #3b82f6; }
    .fabric-deck .agenda-card:nth-child(3):hover { border-color: #3b82f6; box-shadow: 0 4px 16px rgba(59, 130, 246, 0.2); }

    .fabric-deck .agenda-card:nth-child(4) { border-color: rgba(6, 182, 212, 0.25); }
    .fabric-deck .agenda-card:nth-child(4) .agenda-num { color: #06b6d4; }
    .fabric-deck .agenda-card:nth-child(4):hover { border-color: #06b6d4; box-shadow: 0 4px 16px rgba(6, 182, 212, 0.2); }

    .fabric-deck .agenda-card:nth-child(5) { border-color: rgba(234, 179, 8, 0.25); }
    .fabric-deck .agenda-card:nth-child(5) .agenda-num { color: #eab308; }
    .fabric-deck .agenda-card:nth-child(5):hover { border-color: #eab308; box-shadow: 0 4px 16px rgba(234, 179, 8, 0.2); }

    .fabric-deck .agenda-card:hover { transform: translateY(-4px); }

    /* Agent definition cards (slide 1) */
    .fabric-deck .agent-definition-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
      width: 100%;
      max-width: 900px;
    }

    .fabric-deck .def-card {
      position: relative;
      overflow: hidden;
      background: rgba(30, 41, 59, 0.4);
      border: 1px solid var(--fabric-border);
      border-radius: var(--fabric-radius-lg);
      padding: 1rem 1.25rem;
      text-align: left;
      backdrop-filter: blur(12px);
      box-shadow: var(--fabric-shadow);
      transition: all var(--transition-normal);
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .fabric-deck .def-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 3px;
      height: 100%;
      background-color: var(--fabric-border);
      transition: background-color var(--transition-normal);
    }

    .fabric-deck .def-card:hover, .fabric-deck .def-card.active {
      background: rgba(30, 41, 59, 0.7);
      border-color: var(--fabric-primary);
      transform: translateY(-2px);
      box-shadow: 0 4px 16px rgba(96, 165, 250, 0.15);
    }

    .fabric-deck .def-card:hover::before, .fabric-deck .def-card.active::before {
      background-color: var(--fabric-primary);
    }

    .fabric-deck .def-card-icon {
      width: 32px; height: 32px;
      background: rgba(15, 23, 42, 0.6);
      border: 1px solid var(--fabric-border);
      border-radius: var(--fabric-radius);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--fabric-text-muted);
      transition: all var(--transition-normal);
    }

    .fabric-deck .def-card:hover .def-card-icon {
      color: var(--fabric-primary);
      border-color: var(--fabric-primary);
      background: var(--fabric-primary-muted);
    }

    .fabric-deck .def-card-icon svg { width: 18px; height: 18px; }

    .fabric-deck .def-card-title {
      font-family: var(--font-header);
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--fabric-text);
    }

    .fabric-deck .def-card-body {
      font-size: 0.75rem;
      color: var(--fabric-text-secondary);
      line-height: 1.5;
    }

    /* State simulator (slide 2) */
    .fabric-deck .state-simulator {
      display: flex;
      flex-direction: column;
      height: 100%;
      gap: 0.5rem;
    }

    .fabric-deck .sim-visualizer {
      flex: 1;
      display: grid;
      grid-template-rows: auto auto 1fr;
      background: rgba(15, 23, 42, 0.5);
      border: 1px solid var(--fabric-border);
      border-radius: var(--fabric-radius);
      padding: 0.75rem;
      gap: 0.75rem;
    }

    .fabric-deck .sim-row {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }

    .fabric-deck .sim-label {
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--fabric-text-muted);
    }

    .fabric-deck .sim-state-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
    }

    .fabric-deck .state-badge {
      background: var(--fabric-bg-subtle);
      border: 1px solid var(--fabric-border);
      padding: 0.2rem 0.5rem;
      border-radius: 9999px;
      font-size: 0.7rem;
      color: var(--fabric-text-secondary);
      transition: all var(--transition-normal);
    }

    .fabric-deck .state-badge.active-phase {
      background: rgba(59, 130, 246, 0.15);
      border-color: var(--fabric-primary);
      color: var(--fabric-primary);
    }

    .fabric-deck .state-badge.active-activity {
      background: rgba(34, 197, 94, 0.1);
      border-color: var(--fabric-success);
      color: var(--fabric-success);
    }

    .fabric-deck .state-badge.active-activity.blocked {
      background: rgba(245, 158, 11, 0.1);
      border-color: var(--fabric-warning);
      color: var(--fabric-warning);
    }

    .fabric-deck .sim-detail-box {
      background: rgba(15, 23, 42, 0.9);
      border: 1px solid var(--fabric-border);
      border-radius: var(--fabric-radius);
      padding: 0.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }

    .fabric-deck .detail-line {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--fabric-text-secondary);
      line-height: 1.4;
    }

    .fabric-deck .detail-line span { color: var(--fabric-primary); }

    .fabric-deck .sim-controls {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .fabric-deck .sim-btn {
      background: var(--fabric-primary);
      color: var(--fabric-bg);
      border: none;
      padding: 0.35rem 0.75rem;
      font-family: var(--font-header);
      font-weight: 600;
      font-size: 0.75rem;
      border-radius: var(--fabric-radius);
      cursor: pointer;
      transition: all var(--transition-fast);
      display: flex;
      align-items: center;
      gap: 0.3rem;
    }

    .fabric-deck .sim-btn:hover { background: var(--fabric-primary-hover); transform: translateY(-1px); }
    .fabric-deck .sim-btn svg { width: 12px; height: 12px; }

    /* Collaborators graph (slide 3) */
    .fabric-deck .collaborators-svg { display: block; overflow: visible; }

    .fabric-deck .graph-edge { stroke: var(--fabric-border); stroke-width: 2; stroke-linecap: round; fill: none; }

    .fabric-deck .graph-edge-pulse {
      stroke: var(--fabric-primary); stroke-width: 2; stroke-linecap: round;
      stroke-dasharray: 8 32; fill: none;
      animation: deck-laser-fwd 3s linear infinite;
    }

    .fabric-deck .graph-edge-pulse-reverse {
      stroke: var(--fabric-success); stroke-width: 2; stroke-linecap: round;
      stroke-dasharray: 8 32; fill: none;
      animation: deck-laser-bwd 3s linear infinite;
    }

    .fabric-deck .graph-edge-lateral {
      stroke: rgba(148, 163, 184, 0.15); stroke-width: 1.5; fill: none;
    }

    .fabric-deck .graph-node-circle {
      fill: rgba(15, 23, 42, 0.9);
      stroke: var(--fabric-border);
      stroke-width: 2;
      transition: all var(--transition-fast);
    }

    .fabric-deck .graph-node-circle.rect-human { stroke: var(--fabric-primary); stroke-width: 2.5; }
    .fabric-deck .graph-node-circle.rect-parent { stroke: var(--fabric-primary); stroke-width: 2; }
    .fabric-deck .graph-node-circle.rect-child-left { stroke: var(--fabric-success); stroke-width: 2; }
    .fabric-deck .graph-node-circle.rect-child-right { stroke: var(--fabric-info); stroke-width: 2; }

    .fabric-deck .node-emoji-text { font-size: 1.1rem; fill: var(--fabric-text); }

    .fabric-deck .dynamic-node, .fabric-deck .dynamic-edge {
      opacity: 0;
      transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .fabric-deck .dynamic-node.active, .fabric-deck .dynamic-edge.active { opacity: 1; }

    .fabric-deck .graph-node-group { cursor: pointer; transition: all var(--transition-fast); }
    .fabric-deck .graph-node-group:hover { filter: brightness(1.3) drop-shadow(0 0 8px rgba(96, 165, 250, 0.4)); }

    @keyframes deck-laser-fwd { from { stroke-dashoffset: 80; } to { stroke-dashoffset: 0; } }
    @keyframes deck-laser-bwd { from { stroke-dashoffset: -80; } to { stroke-dashoffset: 0; } }

    /* Notification flow (slide 4) */
    .fabric-deck .notif-node-group { transition: opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
    .fabric-deck .notif-node-group.idle { opacity: 0; pointer-events: none; }
    .fabric-deck .notif-node-group.running,
    .fabric-deck .notif-node-group.blocked,
    .fabric-deck .notif-node-group.waiting,
    .fabric-deck .notif-node-group.completed { opacity: 1; }

    .fabric-deck .notif-node-circle { transition: stroke 0.4s, fill 0.4s, opacity 0.4s, filter 0.4s; }
    .fabric-deck .notif-node-circle.idle { stroke: #334155 !important; fill: #0f172a !important; opacity: 0.4; }
    .fabric-deck .notif-node-circle.running { stroke: var(--fabric-primary) !important; fill: rgba(96, 165, 250, 0.1) !important; opacity: 1 !important; filter: drop-shadow(0 0 6px rgba(96, 165, 250, 0.5)); }
    .fabric-deck .notif-node-circle.blocked { stroke: var(--fabric-warning) !important; fill: rgba(245, 158, 11, 0.05) !important; opacity: 1 !important; filter: drop-shadow(0 0 6px rgba(245, 158, 11, 0.5)); animation: deck-pulse-blocked 1.5s infinite alternate; }
    .fabric-deck .notif-node-circle.waiting { stroke: #d946ef !important; fill: rgba(217, 70, 239, 0.1) !important; opacity: 1 !important; filter: drop-shadow(0 0 8px rgba(217, 70, 239, 0.6)); animation: deck-pulse-waiting 1s infinite alternate; }
    .fabric-deck .notif-node-circle.completed { stroke: var(--fabric-success) !important; fill: rgba(34, 197, 94, 0.1) !important; opacity: 1 !important; filter: drop-shadow(0 0 6px rgba(34, 197, 94, 0.5)); }

    .fabric-deck .notif-edge { stroke: var(--fabric-border); stroke-width: 1.5; fill: none; transition: stroke 0.4s; }
    .fabric-deck .notif-edge-pulse { stroke-width: 2; stroke-linecap: round; fill: none; transition: opacity 0.3s; }
    .fabric-deck .state-emoji-overlay { transition: opacity 0.25s ease-out; pointer-events: none; }
    .fabric-deck .notif-node-label { transition: opacity 0.4s; }
    .fabric-deck .pulse-reverse { animation: deck-laser-bwd 2s linear infinite !important; }

    .fabric-deck .secondary-btn:hover:not(:disabled) {
      border-color: var(--fabric-primary) !important;
      color: var(--fabric-primary) !important;
      background: rgba(96, 165, 250, 0.05) !important;
    }

    @keyframes deck-pulse-blocked { from { filter: drop-shadow(0 0 4px rgba(245, 158, 11, 0.2)); } to { filter: drop-shadow(0 0 10px rgba(245, 158, 11, 0.6)); } }
    @keyframes deck-pulse-waiting { from { filter: drop-shadow(0 0 4px rgba(217, 70, 239, 0.3)); } to { filter: drop-shadow(0 0 12px rgba(217, 70, 239, 0.7)); } }

    /* Shared filesystem (slide 5) */
    .fabric-deck .fs-simulator-widget {
      display: flex;
      flex-direction: column;
      height: 100%;
      gap: 0.5rem;
    }

    .fabric-deck .fs-diagram-container {
      flex: 1;
      background: rgba(15, 23, 42, 0.4);
      border: 1px solid var(--fabric-border);
      border-radius: var(--fabric-radius);
      padding: 0.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .fabric-deck .fs-svg { width: 100%; height: 100%; max-height: 200px; display: block; }
    .fabric-deck .fs-tree-edge { stroke: var(--fabric-border); stroke-width: 1.5; stroke-linecap: round; opacity: 0.6; }
    .fabric-deck .fs-op-edge { stroke: var(--fabric-border); stroke-width: 1.5; stroke-dasharray: 4 4; opacity: 0.3; transition: opacity var(--transition-normal); }
    .fabric-deck .fs-op-edge-pulse { stroke-width: 2.5; stroke-dasharray: 6 12; opacity: 0; fill: none; transition: opacity var(--transition-normal); }
    .fabric-deck .fs-op-edge-pulse.write { stroke: var(--fabric-warning); }
    .fabric-deck .fs-op-edge-pulse.read { stroke: var(--fabric-primary); }

    @keyframes deck-fs-dash { to { stroke-dashoffset: -36; } }
    .fabric-deck .fs-op-edge-pulse.active { opacity: 1; animation: deck-fs-dash 1.5s linear infinite; }

    .fabric-deck .fs-node-circle { fill: var(--fabric-bg); stroke-width: 2; transition: all var(--transition-normal); }
    .fabric-deck .fs-node-circle.dir-node { stroke: #475569; fill: rgba(30, 41, 59, 0.9); }
    .fabric-deck .fs-node-circle.file-node { stroke: #334155; fill: rgba(15, 23, 42, 0.85); }
    .fabric-deck .fs-node-circle.file-node.locked { stroke: var(--fabric-warning); fill: rgba(245, 158, 11, 0.08); filter: drop-shadow(0 0 8px rgba(245, 158, 11, 0.3)); }
    .fabric-deck .fs-node-circle.file-node.reading { stroke: var(--fabric-primary); fill: rgba(96, 165, 250, 0.08); filter: drop-shadow(0 0 8px rgba(96, 165, 250, 0.3)); }
    .fabric-deck .fs-node-circle.agent-node { stroke: var(--fabric-border); }
    .fabric-deck .fs-node-circle.agent-node.a1 { stroke: #f59e0b; }
    .fabric-deck .fs-node-circle.agent-node.a2 { stroke: #06b6d4; }

    .fabric-deck .fs-node-label { font-family: var(--font-header); font-size: 0.55rem; font-weight: 600; fill: var(--fabric-text-muted); pointer-events: none; }
    .fabric-deck .lock-overlay { font-size: 0.6rem; opacity: 0; transition: opacity var(--transition-normal); pointer-events: none; filter: drop-shadow(0 0 2px black); }
    .fabric-deck .lock-overlay.active { opacity: 1; }

    .fabric-deck .fs-status-card {
      background: rgba(30, 41, 59, 0.6);
      border: 1px solid var(--fabric-border);
      border-radius: var(--fabric-radius);
      padding: 0.4rem 0.75rem;
      font-family: var(--font-header);
      font-size: 0.7rem;
      color: var(--fabric-text-secondary);
      text-align: center;
      transition: border-color var(--transition-normal), box-shadow var(--transition-normal);
      min-height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .fabric-deck .fs-status-card.active-write { border-color: var(--fabric-warning); box-shadow: 0 0 8px rgba(245, 158, 11, 0.15); }
    .fabric-deck .fs-status-card.active-read { border-color: var(--fabric-primary); box-shadow: 0 0 8px rgba(96, 165, 250, 0.15); }
    .fabric-deck .fs-status-card.active-done { border-color: var(--fabric-success); box-shadow: 0 0 8px rgba(34, 197, 94, 0.15); }

    /* Summary (slide 6) */
    .fabric-deck .summary-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 0.75rem;
      width: 95%;
      max-width: 1000px;
      margin: 0 auto;
    }

    .fabric-deck .summary-card {
      background: rgba(30, 41, 59, 0.35);
      border: 1px solid var(--fabric-border);
      border-radius: var(--fabric-radius-lg);
      padding: 1rem 0.75rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.4rem;
      transition: transform var(--transition-normal), border-color var(--transition-normal), box-shadow var(--transition-normal);
      text-align: center;
    }

    .fabric-deck .summary-card:nth-child(1) { border-color: rgba(245, 158, 11, 0.35); }
    .fabric-deck .summary-card:nth-child(1) .pipeline-card-title { color: #f59e0b; }
    .fabric-deck .summary-card:nth-child(1):hover { border-color: #f59e0b; box-shadow: 0 4px 16px rgba(245, 158, 11, 0.15); }
    .fabric-deck .summary-card:nth-child(2) { border-color: rgba(168, 85, 247, 0.35); }
    .fabric-deck .summary-card:nth-child(2) .pipeline-card-title { color: #a855f7; }
    .fabric-deck .summary-card:nth-child(2):hover { border-color: #a855f7; box-shadow: 0 4px 16px rgba(168, 85, 247, 0.15); }
    .fabric-deck .summary-card:nth-child(3) { border-color: rgba(59, 130, 246, 0.35); }
    .fabric-deck .summary-card:nth-child(3) .pipeline-card-title { color: #3b82f6; }
    .fabric-deck .summary-card:nth-child(3):hover { border-color: #3b82f6; box-shadow: 0 4px 16px rgba(59, 130, 246, 0.15); }
    .fabric-deck .summary-card:nth-child(4) { border-color: rgba(6, 182, 212, 0.35); }
    .fabric-deck .summary-card:nth-child(4) .pipeline-card-title { color: #06b6d4; }
    .fabric-deck .summary-card:nth-child(4):hover { border-color: #06b6d4; box-shadow: 0 4px 16px rgba(6, 182, 212, 0.15); }
    .fabric-deck .summary-card:nth-child(5) { border-color: rgba(234, 179, 8, 0.35); }
    .fabric-deck .summary-card:nth-child(5) .pipeline-card-title { color: #eab308; }
    .fabric-deck .summary-card:nth-child(5):hover { border-color: #eab308; box-shadow: 0 4px 16px rgba(234, 179, 8, 0.15); }

    .fabric-deck .summary-card:hover { transform: translateY(-3px); }

    .fabric-deck .summary-card .pipeline-card-icon {
      height: 36px; width: 100%;
      display: flex; align-items: center; justify-content: center;
      overflow: visible;
      transition: transform var(--transition-normal);
    }

    .fabric-deck .summary-card .pipeline-card-icon svg { width: 100%; height: 100%; overflow: visible; }
    .fabric-deck .summary-card:hover .pipeline-card-icon { transform: scale(1.08); }

    .fabric-deck .summary-card .pipeline-card-title {
      font-family: var(--font-header);
      font-size: 0.9rem;
      font-weight: 700;
      margin: 0;
    }

    .fabric-deck .summary-card .pipeline-card-body {
      font-size: 0.7rem;
      line-height: 1.5;
      color: var(--fabric-text-secondary);
      margin: 0;
    }

    @keyframes deck-spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

    /* Responsive for the deck */
    @media (max-width: 900px) {
      .fabric-deck { aspect-ratio: auto; min-height: 500px; }
      .fabric-deck .slide { grid-template-columns: 1fr; grid-template-rows: auto 1fr; overflow-y: auto; padding: 1rem; gap: 1rem; }
      .fabric-deck .slide-visual { height: 300px; }
      .fabric-deck .agenda-grid { grid-template-columns: repeat(3, 1fr); }
      .fabric-deck .summary-grid { grid-template-columns: repeat(3, 1fr); }
      .fabric-deck .agent-definition-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <!-- Hero -->
  <section class="hero">
    <img src={`${base}/fabric-graphic.png`} alt="Fabric" class="hero-graphic" />
    <p class="hero-tagline">sci·on /ˈsīən/ — a young shoot or twig, cut for grafting or rooting.</p>
    <p class="hero-subtitle">
      A containerized orchestration system for multi-agent workflows.
      Run multiple AI agents in parallel — each in its own sandbox, with isolated workspaces —
      collaborating on your code simultaneously.
    </p>
    <div class="hero-buttons">
      <a href="https://pdlc-os.github.io/fabric/getting-started/install/" class="btn btn-primary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"/><polyline points="7 11 12 16 17 11"/><line x1="12" y1="4" x2="12" y2="16"/></svg>
        Get Started
      </a>
      <a href="https://github.com/pdlc-os/fabric" class="btn btn-secondary">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        GitHub
      </a>
      <a href={`${base}/overview/`} class="btn btn-secondary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
        Documentation
      </a>
    </div>
  </section>

  <!-- Integrated Fabric Core Slideshow -->
  <section class="landing-section" style="background: var(--bg-secondary); border-top: 1px solid var(--border-subtle); border-bottom: 1px solid var(--border-subtle);">
    <div class="section-inner" style="max-width: 1200px;">
      <h2 class="section-title">Fabric Core</h2>
      <p class="section-subtitle">A five-part containerized orchestration system for multi-agent workflows.</p>

      <div class="fabric-deck" id="fabric-deck">
        <!-- Background glows -->
        <div class="bg-glows">
          <div class="bg-glow-1"></div>
          <div class="bg-glow-2"></div>
        </div>

        <!-- Header -->
        <header class="presentation-header">
          <div class="logo-container">
            <span style="font-size: 1.2rem; filter: drop-shadow(0 0 4px rgba(96, 165, 250, 0.2));">🌱</span>
            <h1 class="logo-text">FABRIC<span>.</span></h1>
          </div>
          <div class="deck-title">Multi-Agent Orchestration Explainer</div>
        </header>

        <!-- Slides -->
        <main class="slides-wrapper" id="deck-slides-wrapper">

          <!-- Slide 0: Agenda -->
          <section class="slide active slide-full" id="deck-slide-0">
            <h2 class="slide-title" style="font-size: 1.8rem; margin-bottom: 0.3rem;">Fabric Core</h2>
            <p class="slide-desc" style="max-width: 600px; margin-bottom: 1.5rem; text-align: center; font-size: 0.9rem;">
              A five-part containerized orchestration system for multi-agent workflows.
            </p>
            <div class="agenda-grid">
              <div class="agenda-card" data-target-slide="1">
                <div class="agenda-num">01</div>
                <h3 class="agenda-title">Define</h3>
                <p class="agenda-subtitle">Agent Templates</p>
