    <div class="cta-links">
      <a href="https://github.com/pdlc-os/fabric" class="btn btn-primary">
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        View on GitHub
      </a>
      <a href={`${base}/overview/`} class="btn btn-secondary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
        Read the Docs
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="landing-footer">
    <p>Fabric is an open-source project by <a href="https://cloud.google.com">Google Cloud</a>. Not an officially supported Google product.</p>
    <p style="margin-top: 0.5rem;">Apache License 2.0 &middot; <a href="https://github.com/pdlc-os/fabric">GitHub</a></p>
  </footer>

  <!-- Slideshow Controller Script -->
  <script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const deck = document.getElementById('fabric-deck');
    if (!deck) return;

    // Navigation
    const slides = deck.querySelectorAll('.slide');
    const dots = deck.querySelectorAll('.progress-dot');
    const prevBtn = document.getElementById('deck-prev-btn');
    const nextBtn = document.getElementById('deck-next-btn');
    const progressBar = document.getElementById('deck-progress-bar');
    let currentSlideIndex = 0;
    const totalSlides = slides.length;

    function updateNavigation() {
      slides.forEach((slide, idx) => {
        slide.classList.remove('active', 'previous');
        if (idx === currentSlideIndex) slide.classList.add('active');
        else if (idx < currentSlideIndex) slide.classList.add('previous');
      });
      dots.forEach((dot, idx) => dot.classList.toggle('active', idx === currentSlideIndex));
      progressBar.style.width = ((currentSlideIndex / (totalSlides - 1)) * 100) + '%';
      prevBtn.disabled = currentSlideIndex === 0;
      nextBtn.disabled = currentSlideIndex === totalSlides - 1;
    }

    function goToSlide(index) {
      if (index >= 0 && index < totalSlides) { currentSlideIndex = index; updateNavigation(); }
    }

    prevBtn.addEventListener('click', () => { if (currentSlideIndex > 0) goToSlide(currentSlideIndex - 1); });
    nextBtn.addEventListener('click', () => { if (currentSlideIndex < totalSlides - 1) goToSlide(currentSlideIndex + 1); });
    dots.forEach(dot => dot.addEventListener('click', () => goToSlide(parseInt(dot.getAttribute('data-slide')) - 1)));
    deck.querySelectorAll('.agenda-card').forEach(card => card.addEventListener('click', () => goToSlide(parseInt(card.getAttribute('data-target-slide')))));

    // Keyboard nav (only when deck is in viewport)
    window.addEventListener('keydown', (e) => {
      const rect = deck.getBoundingClientRect();
      const inView = rect.top < window.innerHeight && rect.bottom > 0;
      if (!inView) return;
      if (e.key === 'ArrowRight') { e.preventDefault(); if (currentSlideIndex < totalSlides - 1) goToSlide(currentSlideIndex + 1); }
      else if (e.key === 'ArrowLeft') { e.preventDefault(); if (currentSlideIndex > 0) goToSlide(currentSlideIndex - 1); }
    });

    // Touch swipe
    let touchStartX = 0;
    deck.addEventListener('touchstart', (e) => { touchStartX = e.changedTouches[0].screenX; }, { passive: true });
    deck.addEventListener('touchend', (e) => {
      const diff = e.changedTouches[0].screenX - touchStartX;
      if (diff < -50 && currentSlideIndex < totalSlides - 1) goToSlide(currentSlideIndex + 1);
      if (diff > 50 && currentSlideIndex > 0) goToSlide(currentSlideIndex - 1);
    }, { passive: true });

    updateNavigation();

    // Slide 1: Definition card active toggle
    deck.querySelectorAll('.def-card').forEach(card => {
      card.addEventListener('click', () => {
        deck.querySelectorAll('.def-card').forEach(c => c.classList.remove('active'));
        card.classList.add('active');
      });
    });

    // Slide 2: State simulator
    const phaseBadges = deck.querySelectorAll('#deck-phase-badges .state-badge');
    const activityBadges = deck.querySelectorAll('#deck-activity-badges .state-badge');
    const detailPhase = document.getElementById('deck-detail-phase');
    const detailActivity = document.getElementById('deck-detail-activity');
    const detailText = document.getElementById('deck-detail-text');
    const stepBtn = document.getElementById('deck-next-state-btn');

    const simSteps = [
      { phase: 'provisioning', activity: 'offline', text: 'Allocating sandbox container namespace & credentials...' },
      { phase: 'provisioning', activity: 'offline', text: 'Workspace provisioning: mounting secure environment vars...' },
      { phase: 'running', activity: 'working', text: 'Checking workspace files. Reading package.json...' },
      { phase: 'running', activity: 'thinking', text: 'Thinking... Analyzing import structures...' },
      { phase: 'running', activity: 'working', text: 'Writing fix changes. Initiating local test suite...' },
      { phase: 'running', activity: 'blocked', text: 'Suspended parent execution. Child task delegated: waiting on qa-agent...' },
      { phase: 'running', activity: 'waiting_for_input', text: 'Human interaction required: waiting for merge approval...' },
      { phase: 'running', activity: 'working', text: 'Action approved! Merging branch to main...' },
      { phase: 'stopping', activity: 'offline', text: 'Stopping agent execution loop. Unmounting shadow volumes...' },
      { phase: 'stopped', activity: 'offline', text: 'Agent offline. Workspace archived. Container safely deleted.' }
    ];
    let simIndex = 0;

    function runStateStep() {
      const step = simSteps[simIndex];
      phaseBadges.forEach(b => b.classList.toggle('active-phase', b.getAttribute('data-phase') === step.phase));
      activityBadges.forEach(b => {
        b.classList.remove('active-activity', 'blocked');
        if (b.getAttribute('data-activity') === step.activity) {
          b.classList.add('active-activity');
          if (step.activity === 'blocked' || step.activity === 'waiting_for_input') b.classList.add('blocked');
        }
      });
      detailPhase.textContent = step.phase;
      detailActivity.textContent = step.activity;
      detailText.textContent = step.text;
      simIndex = (simIndex + 1) % simSteps.length;
    }

    stepBtn.addEventListener('click', runStateStep);
    runStateStep();

    // Slide 3: Collaborators graph loop
    const dynNodes = { '1a': 'deck-node-child-1a', '1b': 'deck-node-child-1b', '2a': 'deck-node-child-2a', '3a': 'deck-node-child-3a' };
    const dynEdges = {
      '1a': ['deck-edge-a1-c1a', 'deck-pulse-a1-c1a'], '1b': ['deck-edge-a1-c1b', 'deck-pulse-a1-c1b'],
      '2a': ['deck-edge-a2-c2a', 'deck-pulse-a2-c2a'], '3a': ['deck-edge-a3-c3a', 'deck-pulse-a3-c3a']
    };

    function setDynState(id, visible) {
      const node = document.getElementById(dynNodes[id]);
      if (node) node.classList.toggle('active', visible);
      dynEdges[id].forEach(eid => { const el = document.getElementById(eid); if (el) el.classList.toggle('active', visible); });
    }

    let loopStep = 0;
    function runCollabLoop() {
      switch (loopStep) {
        case 0: setDynState('1a',false); setDynState('1b',false); setDynState('2a',false); setDynState('3a',false); loopStep=1; break;
        case 1: setDynState('1a',true); setDynState('1b',true); loopStep=2; break;
        case 2: setDynState('3a',true); loopStep=3; break;
        case 3: setDynState('2a',true); setDynState('1b',false); loopStep=4; break;
        case 4: setDynState('1a',false); setDynState('3a',false); loopStep=5; break;
        case 5: setDynState('2a',false); loopStep=0; break;
      }
    }
    setInterval(runCollabLoop, 2000);
    runCollabLoop();

    // Slide 4: Notification flow
    const nCircles = {};
    const nOverlays = {};
    const nPulses = {};
    const nEdges = {};
    ['coord','left','right','lc1','lc2','lc3','rc1'].forEach(k => {
      nCircles[k] = document.getElementById('deck-node-' + k);
      nOverlays[k] = nCircles[k] ? nCircles[k].querySelector('.state-emoji-overlay') : null;
    });
    ({cl:'deck-pulse-c-l', cr:'deck-pulse-c-r', l1:'deck-pulse-l-lc1', l2:'deck-pulse-l-lc2', l3:'deck-pulse-l-lc3', r1:'deck-pulse-r-rc1'}).constructor;
    ['cl','cr','l1','l2','l3','r1'].forEach(k => {
      const map = {cl:'c-l', cr:'c-r', l1:'l-lc1', l2:'l-lc2', l3:'l-lc3', r1:'r-rc1'};
      nPulses[k] = document.getElementById('deck-pulse-' + map[k]);
      nEdges[k] = document.getElementById('deck-edge-' + map[k]);
    });

    const nPlayBtn = document.getElementById('deck-notif-play-btn');
    const nResetBtn = document.getElementById('deck-notif-reset-btn');
    let nTimeouts = [];

    function setNState(key, state, emoji) {
      const g = nCircles[key]; if (!g) return;
      g.classList.remove('idle','running','blocked','waiting','completed'); g.classList.add(state);
      const c = g.querySelector('circle'); if (c) { c.classList.remove('idle','running','blocked','waiting','completed'); c.classList.add(state); }
      const o = nOverlays[key]; if (o) { if (emoji) { o.textContent = emoji; o.style.opacity = '1'; } else { o.style.opacity = '0'; } }
    }

    function setNPulse(key, active, reverse) {
      const el = nPulses[key]; if (!el) return;
      el.style.opacity = active ? '1' : '0';
      if (active) { el.classList.remove('pulse-reverse'); if (reverse) el.classList.add('pulse-reverse'); }
    }

    function setNEdge(key, active) { const el = nEdges[key]; if (el) el.style.opacity = active ? '1' : '0'; }

    function resetNotif() {
      nTimeouts.forEach(clearTimeout); nTimeouts = [];
      setNState('coord','running'); setNState('left','idle'); setNState('right','idle');
      setNState('lc1','idle'); setNState('lc2','idle'); setNState('lc3','idle'); setNState('rc1','idle');
      Object.keys(nPulses).forEach(p => setNPulse(p, false));
      Object.keys(nEdges).forEach(e => setNEdge(e, false));
      nPlayBtn.disabled = false; nPlayBtn.style.opacity = '1'; nPlayBtn.style.cursor = 'pointer';
      nPlayBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px;"><polygon points="5 3 19 12 5 21 5 3"/></svg> Run Orchestration';
      nResetBtn.disabled = true; nResetBtn.style.opacity = '0.5'; nResetBtn.style.cursor = 'not-allowed';
    }

    function startNotif() {
      nPlayBtn.disabled = true; nPlayBtn.style.opacity = '0.5'; nPlayBtn.style.cursor = 'not-allowed';
      nPlayBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px;"><circle cx="12" cy="12" r="10"/></svg> Running...';
      nResetBtn.disabled = true; nResetBtn.style.opacity = '0.5'; nResetBtn.style.cursor = 'not-allowed';
      nTimeouts.forEach(clearTimeout); nTimeouts = [];

      setNState('coord','running','🧠'); setNPulse('cl',true); setNPulse('cr',true);
      nTimeouts.push(setTimeout(() => {
        setNPulse('cl',false); setNPulse('cr',false); setNState('coord','running');
        setNState('left','running','🧠'); setNState('right','running','🧠');
        setNEdge('cl',true); setNEdge('cr',true);
      }, 900));
      nTimeouts.push(setTimeout(() => {
        setNState('left','blocked','🚧'); setNState('right','blocked','🚧');
        nTimeouts.push(setTimeout(() => { setNState('lc1','running'); setNEdge('l1',true); setNPulse('l1',true); nTimeouts.push(setTimeout(() => setNPulse('l1',false), 700)); }, 100));
        nTimeouts.push(setTimeout(() => { setNState('lc2','running'); setNEdge('l2',true); setNPulse('l2',true); nTimeouts.push(setTimeout(() => setNPulse('l2',false), 700)); }, 400));
        nTimeouts.push(setTimeout(() => { setNState('lc3','running'); setNEdge('l3',true); setNPulse('l3',true); nTimeouts.push(setTimeout(() => setNPulse('l3',false), 700)); }, 700));
        nTimeouts.push(setTimeout(() => { setNState('rc1','running'); setNEdge('r1',true); setNPulse('r1',true); nTimeouts.push(setTimeout(() => setNPulse('r1',false), 700)); }, 350));
      }, 2000));
      nTimeouts.push(setTimeout(() => {
        setNState('lc2','completed','✅'); setNState('left','running','🧠');
        setNState('rc1','waiting','❓'); setNState('right','running','🧠');
        nTimeouts.push(setTimeout(() => { setNState('left','running'); setNState('right','running'); }, 800));
      }, 4000));
      nTimeouts.push(setTimeout(() => setNState('lc1','completed','✅'), 5000));
      nTimeouts.push(setTimeout(() => {
        setNState('rc1','completed','✅'); setNState('right','completed','✅');
        setNPulse('cr',true,true); nTimeouts.push(setTimeout(() => setNPulse('cr',false), 700));
      }, 5300));
      nTimeouts.push(setTimeout(() => {
        setNState('lc3','completed','✅'); setNState('left','completed','✅');
        setNPulse('cl',true,true); nTimeouts.push(setTimeout(() => setNPulse('cl',false), 700));
      }, 6500));
      nTimeouts.push(setTimeout(() => {
        setNState('coord','completed','✅');
        nPlayBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px;"><polyline points="20 6 9 17 4 12"/></svg> Flow Completed';
        nResetBtn.disabled = false; nResetBtn.style.opacity = '1'; nResetBtn.style.cursor = 'pointer';
      }, 7500));
    }

    nPlayBtn.addEventListener('click', startNotif);
    nResetBtn.addEventListener('click', resetNotif);

    // Slide 5: Filesystem simulator
    const fsPlayBtn = document.getElementById('deck-fs-play-btn');
    const fsResetBtn = document.getElementById('deck-fs-reset-btn');
    const fsStatus = document.getElementById('deck-fs-status-card');
    const fsPulseAuth = document.getElementById('deck-pulse-a1-auth');
    const fsPulseServer = document.getElementById('deck-pulse-a2-server');
    const fsPulseTest = document.getElementById('deck-pulse-a2-test');
    const fsEdgeAuth = document.getElementById('deck-edge-a1-auth');
    const fsEdgeServer = document.getElementById('deck-edge-a2-server');
    const fsEdgeTest = document.getElementById('deck-edge-a2-test');
    const fsCircleAuth = document.getElementById('deck-circle-auth');
    const fsCircleServer = document.getElementById('deck-circle-server');
    const fsCircleTest = document.getElementById('deck-circle-test');
    const fsLockAuth = document.getElementById('deck-lock-auth');
    const fsLockServer = document.getElementById('deck-lock-server');
    const fsLockTest = document.getElementById('deck-lock-test');
    const fsDotAuth = document.getElementById('deck-dot-a1-auth');
    const fsDotServer = document.getElementById('deck-dot-a2-server');
    const fsDotTest = document.getElementById('deck-dot-a2-test');
    const fsAnimAuth = document.getElementById('deck-anim-a1-auth');
    const fsAnimServer = document.getElementById('deck-anim-a2-server');
    const fsAnimTest = document.getElementById('deck-anim-a2-test');
    let fsTimeouts = [];

    function resetFs() {
      fsTimeouts.forEach(clearTimeout); fsTimeouts = [];
      [fsPulseAuth, fsPulseServer, fsPulseTest].forEach(el => el.classList.remove('active'));
      [fsEdgeAuth, fsEdgeServer, fsEdgeTest].forEach(el => { el.style.opacity = '0.3'; });
      [fsCircleAuth, fsCircleServer, fsCircleTest].forEach(el => el.classList.remove('locked','reading'));
      [fsLockAuth, fsLockServer, fsLockTest].forEach(el => el.classList.remove('active'));
      [fsDotAuth, fsDotServer, fsDotTest].forEach(el => el.setAttribute('opacity','0'));
      [fsAnimAuth, fsAnimServer, fsAnimTest].forEach(el => { try { el.endElement(); } catch(e){} });
      fsStatus.className = 'fs-status-card';
      fsStatus.textContent = 'Click "Run Simulation" to observe concurrent filesystem operations.';
      fsPlayBtn.disabled = false; fsPlayBtn.style.opacity = '1'; fsPlayBtn.style.cursor = 'pointer';
      fsPlayBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px;"><polygon points="5 3 19 12 5 21 5 3"/></svg> Run Simulation';
      fsResetBtn.disabled = true; fsResetBtn.style.opacity = '0.5'; fsResetBtn.style.cursor = 'not-allowed';
    }

    function startFs() {
      fsPlayBtn.disabled = true; fsPlayBtn.style.opacity = '0.5'; fsPlayBtn.style.cursor = 'not-allowed';
      fsPlayBtn.innerHTML = 'Simulating...';
      fsResetBtn.disabled = false; fsResetBtn.style.opacity = '1'; fsResetBtn.style.cursor = 'pointer';

      fsTimeouts.push(setTimeout(() => {
        fsPulseAuth.classList.add('active'); fsEdgeAuth.style.opacity = '1';
        fsCircleAuth.classList.add('locked'); fsLockAuth.classList.add('active');
        fsDotAuth.setAttribute('opacity','1'); try { fsAnimAuth.beginElement(); } catch(e){}
        fsStatus.className = 'fs-status-card active-write';
        fsStatus.textContent = 'Agent 1 acquired write lease for src/auth.py. Lock active.';
      }, 0));

      fsTimeouts.push(setTimeout(() => {
        fsPulseServer.classList.add('active'); fsEdgeServer.style.opacity = '1';
        fsCircleServer.classList.add('reading');
        fsDotServer.setAttribute('opacity','1'); try { fsAnimServer.beginElement(); } catch(e){}
        fsStatus.className = 'fs-status-card active-read';
        fsStatus.textContent = 'Agent 2 reading src/server.py concurrently. Safe shared file access.';
      }, 2000));

      fsTimeouts.push(setTimeout(() => {
        fsPulseAuth.classList.remove('active'); fsEdgeAuth.style.opacity = '0.3';
        fsCircleAuth.classList.remove('locked'); fsLockAuth.classList.remove('active');
        fsDotAuth.setAttribute('opacity','0'); try { fsAnimAuth.endElement(); } catch(e){}
        fsPulseServer.classList.remove('active'); fsEdgeServer.style.opacity = '0.3';
        fsCircleServer.classList.remove('reading'); fsDotServer.setAttribute('opacity','0');
        try { fsAnimServer.endElement(); } catch(e){}
        fsPulseTest.classList.add('active'); fsEdgeTest.style.opacity = '1';
        fsCircleTest.classList.add('locked'); fsLockTest.classList.add('active');
        fsDotTest.setAttribute('opacity','1'); try { fsAnimTest.beginElement(); } catch(e){}
        fsStatus.className = 'fs-status-card active-write';
        fsStatus.textContent = 'Agent 2 acquired write lease for tests/test_auth.py. Lock active.';
      }, 4200));

      fsTimeouts.push(setTimeout(() => {
        fsPulseTest.classList.remove('active'); fsEdgeTest.style.opacity = '0.3';
        fsCircleTest.classList.remove('locked'); fsLockTest.classList.remove('active');
        fsDotTest.setAttribute('opacity','0'); try { fsAnimTest.endElement(); } catch(e){}
        fsStatus.className = 'fs-status-card active-done';
        fsStatus.textContent = 'All locks released. Filesystem synchronized.';
      }, 6200));

      fsTimeouts.push(setTimeout(() => {
        fsPlayBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px;"><polyline points="20 6 9 17 4 12"/></svg> Simulation Finished';
      }, 7500));
    }

    fsPlayBtn.addEventListener('click', startFs);
    fsResetBtn.addEventListener('click', resetFs);
  });
  </script>

