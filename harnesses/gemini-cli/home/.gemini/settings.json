{
  "yolo": true,
  "security": {
    "auth": {},
    "folderTrust": {
      "enabled": false
    },
    "allowedEnvironmentVariables": ["FABRIC_AGENT_ID", "FABRIC_AGENT_NAME", "FABRIC_AGENT_SLUG", "FABRIC_AUTH_TOKEN", "FABRIC_BROKER_ID", "FABRIC_BROKER_NAME", "FABRIC_CREATOR", "FABRIC_DEBUG", "FABRIC_GROVE", "FABRIC_GROVE_ID", "FABRIC_GROVE_PATH", "FABRIC_PROJECT", "FABRIC_PROJECT_ID", "FABRIC_PROJECT_PATH", "FABRIC_HARNESS", "FABRIC_HOST_GID", "FABRIC_HOST_UID", "FABRIC_HUB_ENDPOINT", "FABRIC_HUB_URL", "FABRIC_MODEL", "FABRIC_OTEL_ENDPOINT", "FABRIC_OTEL_GCP_CREDENTIALS", "FABRIC_OTEL_PROTOCOL", "FABRIC_SHARED_WORKSPACE", "FABRIC_TELEMETRY_CLOUD_ENABLED", "FABRIC_TELEMETRY_CLOUD_PROVIDER", "FABRIC_TELEMETRY_DEBUG", "FABRIC_TELEMETRY_ENABLED", "FABRIC_TELEMETRY_HUB_ENABLED", "FABRIC_TELEMETRY_LOCAL_CONSOLE", "FABRIC_TELEMETRY_LOCAL_ENABLED", "FABRIC_TEMPLATE", "FABRIC_TEMPLATE_NAME", "GITHUB_TOKEN"]
  },
  "context": {
    "fileName": ["CLAUDE.md","AGENTS.md", "GEMINI.md"],
    "fileFiltering": {
      "customIgnoreFilePaths": ["/home/fabric/.gemini/.geminiignore"]
    }
  },
  "model": {
    "skipNextSpeakerCheck": true,
    "name": "gemini-3.5-flash"
  },
  "telemetry": {
    "enabled": true
  },
  "general": {
    "disableAutoUpdate": true,
    "disableUpdateNag": true,
    "previewFeatures": true
  },
  "ui": {
    "accessibility": {
      "disableLoadingPhrases": true
    },
    "hideFooter": true,
    "hideWindowTitle": true
  },
  "tools": {
    "enableMessageBusIntegration": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "fabric-status",
            "type": "command",
            "command": "fabrictool hook --dialect=gemini"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "fabric-status",
            "type": "command",
            "command": "fabrictool hook --dialect=gemini"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "fabric-status",
            "type": "command",
            "command": "fabrictool hook --dialect=gemini"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "fabric-status",
            "type": "command",
            "command": "fabrictool hook --dialect=gemini"
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "fabric-status",
            "type": "command",
            "command": "fabrictool hook --dialect=gemini"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "fabric-status",
            "type": "command",
            "command": "fabrictool hook --dialect=gemini"
          }
        ]
      }
    ],
    "BeforeModel": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "fabric-status",
            "type": "command",
            "command": "fabrictool hook --dialect=gemini"
          }
        ]
      }
    ],
    "AfterModel": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "fabric-status",
            "type": "command",
            "command": "fabrictool hook --dialect=gemini"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "ToolPermission",
        "hooks": [
          {
            "name": "fabric-status",
            "type": "command",
            "command": "fabrictool hook --dialect=gemini"
          }
        ]
      }
    ]
  },
  "experimental": {
    "modelSteering": true
  }
}
