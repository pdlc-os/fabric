{
  "yolo": true,
  "security": {
    "auth": {},
    "folderTrust": {
      "enabled": false
    }
  },
  "context": {
    "fileName": ["CLAUDE.md","AGENTS.md", "GEMINI.md"],
    "fileFiltering": {
      "customIgnoreFilePaths": ["/home/fabric/.gemini/.geminiignore"]
    }
  },
  "model": {
    "skipNextSpeakerCheck": true,
    "name": "gemini-3-flash-preview"
  },
  "telemetry": {
    "enabled": false
  },
  "general": {
    "disableAutoUpdate": true,
    "disableUpdateNag": true,
    "previewFeatures": true
  },
  "ui": {
    "accessibility": {
      "disableLoadingPhrases": true
    },
    "hideFooter": true,
    "hideWindowTitle": true
  },
  "tools": {
    "enableMessageBusIntegration": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "fabric-status",
            "type": "command",
            "command": "fabrictool hook --dialect=gemini"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "fabric-status",
            "type": "command",
            "command": "fabrictool hook --dialect=gemini"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "fabric-status",
            "type": "command",
            "command": "fabrictool hook --dialect=gemini"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "fabric-status",
            "type": "command",
            "command": "fabrictool hook --dialect=gemini"
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "fabric-status",
            "type": "command",
            "command": "fabrictool hook --dialect=gemini"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "fabric-status",
            "type": "command",
            "command": "fabrictool hook --dialect=gemini"
          }
        ]
      }
    ],
    "BeforeModel": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "fabric-status",
            "type": "command",
            "command": "fabrictool hook --dialect=gemini"
          }
        ]
      }
    ],
    "AfterModel": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "fabric-status",
            "type": "command",
            "command": "fabrictool hook --dialect=gemini"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "ToolPermission",
        "hooks": [
          {
            "name": "fabric-status",
            "type": "command",
            "command": "fabrictool hook --dialect=gemini"
          }
        ]
      }
    ]
  },
  "experimental": {
    "modelSteering": true
  }
}
